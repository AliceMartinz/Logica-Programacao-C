#include <stdio.h>

int main(void) 
{
  int i, j, opcao, codigo_planta, codigo_planta2, aux, aux2;
  int cont1=0, cont2=0, cont3=0, cont4=0, auxi[15];
  float somatorio=0, media=0, maior1=0, maior2=0, cont=0, lucro=0;
  int maior_quantidade=0;
  float v1[100], lucro;
  struct lista_plantas
  {
    char nome[20];
    int cod;
    float valor_compra;
    float valor_venda;
    float toneladas;
    int periodo;
    float lucro[100];
  };
  struct lista_plantas plantas[15];
  do
    {
      aux = 0;
      aux2=0;
      printf("\n\n-----MENU DE OPÇÕES-----\n");
      printf("\n1 - Cadastrar Plantas (obrigatório);");
      printf("\n2 - Exibir Comparativo;");
      printf("\n3 - Exibir total de plantas por período;");
      printf("\n4 - Exibir valor médio gasto com grãos;");
      printf("\n5 - Exibir plantas com maior valor de venda;");
      printf("\n6 - Exibir planta(s) com maior quantidade produzida;");
      printf("\n7 - Atualizar produção;\n");
      printf("\n8 - ;\n");
      printf("\nInforme uma opção: \n\n>> ");
      scanf("%d", &opcao);
      if(opcao == 0)
      {
        break;
      }
      if(opcao == 1)
      {
        cont = 0;
        somatorio = 0;
        for(i=0; i<3; i++)
            {
              printf("\nInforme o nome da planta: \n\n>> ");
              scanf("%s", plantas[i].nome);
              printf("\nInforme o codigo da planta: \n\n>> ");
              scanf("%d", &plantas[i].cod);
              printf("\nInforme o valor da compra dos grãos: \n\n>> ");
              scanf("%f", &plantas[i].valor_compra);
              somatorio += plantas[i].valor_compra;
              cont++;
              printf("\nInforme o valor de venda dos produtos: \n\n>> ");
              scanf("%f", &plantas[i].valor_venda);
              printf("\nInforme a quantidade de toneladas: \n\n>> ");
              scanf("%f", &plantas[i].toneladas);
              printf("\n\n-----PERÍODOS-----\n");
              printf("\n1 - Verão");
              printf("\n2 - Primevera");
              printf("\n3 - Outono");
              printf("\n4 - Inverno");
              printf("\n\n------------------\n");
              printf("\nInforme o período de plantio: \n\n>> ");
              scanf("%d", &plantas[i].periodo);
              if(plantas[i].periodo == 1)
              {
                cont1++;
              }
              if(plantas[i].periodo == 2)
              {
                cont2++;
              }
              if(plantas[i].periodo == 3)
              {
                cont3++;
              }
              if(plantas[i].periodo == 4)
              {
                cont4++;
              }
             
            }
      }
      switch(opcao)
        {
          case 2:
            printf("\nInforme o código da primeira planta: \n\n>> ");
            scanf("%d", &codigo_planta);
            printf("\nInforme o código da segunda planta: \n\n>> ");
            scanf("%d", &codigo_planta2);
            printf("\n----------------\n");
            printf("\n> RESULTADO <\n");
            printf("\n----------------\n");
            for(i=0; i<15; i++)
              {
                if(plantas[i].cod == codigo_planta)
                {
                  aux = i;
                  printf("\n.Nome da primeira Planta: \n\n- > %s\n\n", plantas[aux].nome);
                  printf("\n.Valor de Compra: \n\n- > %.2f\n\n", plantas[aux].valor_compra);
                  printf("\n.Valor de Venda: \n\n- > %.2f\n\n", plantas[aux].valor_venda);
                  printf("\n.Toneladas: \n\n- > %.2f\n\n", plantas[aux].toneladas);
                  printf("\n.Período: \n\n- > %d\n\n", plantas[aux].periodo);
                }
                if(plantas[i].cod == codigo_planta2)
                {
                  aux = i;
                  printf("\n.Nome da segunda Planta: \n\n- > %s\n\n", plantas[aux].nome);
                  printf("\n.Valor de Compra: \n\n- > %.2f\n\n", plantas[aux].valor_compra);
                  printf("\n.Valor de Venda: \n\n- > %.2f\n\n", plantas[aux].valor_venda);
                  printf("\n.Toneladas: \n\n- > %.2f\n\n", plantas[aux].toneladas);
                  printf("\n.Período: \n\n- > %d\n\n", plantas[aux].periodo);
                }
              }
          break;
          case 3:
            printf("\n\n------------------\n");
            printf("\nVERÃO --> %d\n", cont1);
            printf("\nPRIMAVERA --> %d\n", cont2);
            printf("\nOUTONO --> %d\n", cont3);
            printf("\nINVERNO --> %d\n", cont4);
            printf("\n\n------------------\n");
          break;

          case 4:
          media = somatorio/cont;
          printf("\n\n------------------\n");
          printf("\n--> A média de compra dos grãos é de: R$%.2f\n", media);
          printf("\n\n------------------\n");
          break;
          
          case 5:
          maior1=0;
          maior2=0;
          for(i=0; i<15; i++)
            {
              if(plantas[i].valor_venda > maior1)
              {
                maior2 = maior1;
                maior1 = plantas[i].valor_venda;
                aux = i;
              }
              else if(plantas[i].valor_venda > maior2)
              {
                maior2 = plantas[i].valor_venda;
                aux2 = i;
              }
            }
            printf("\n\n------------------\n");
            printf("\nPlantas com maiores quantidades de venda: -->");
            printf("\n\n------------------\n");
            printf("\n.%s", plantas[aux].nome);
            printf("\n.%s", plantas[aux2].nome);
            printf("\n\n------------------\n");
          break;

          case 6:
          cont=0;
          for(i=0; i<15; i++)
            {
              if(plantas[i].toneladas > maior_quantidade)
              {
                maior_quantidade = plantas[i].toneladas;
              }
              if(plantas[i].toneladas == maior_quantidade)
              {
                auxi[i] = i;
                cont++;
              }
            }
          printf("\n\n------------------\n");
          printf("\nPlantas com maiores quantidades de produção: -->");
          printf("\n\n------------------\n");
          for(i=0; i<cont; i++)
            {
              printf("\n.%s", plantas[auxi[i]].nome);
            }
          break;
          case 7:
          codigo_planta = 0;
          aux=0;
          printf("\nInforme o código de uma planta: \n\n>> ");
          scanf("%d", &codigo_planta);
          for(i=0; i<15; i++)
            {
              if(plantas[i].cod == codigo_planta)
              {
                aux=i;
                printf("\nInforme o valor da compra dos grãos: \n\n>> ");
                scanf("%f", &plantas[aux].valor_compra);
                printf("\nInforme o valor de venda dos produtos: \n\n>> ");
                scanf("%f", &plantas[aux].valor_venda);
                printf("\nInforme a quantidade de toneladas: \n\n>> ");
                scanf("%f", &plantas[aux].toneladas);
              }
            }
            printf("\nInformações Atualizadas!\n");
          break;
          
          default:
          printf("\n.Opção Inexistente.");
        }
      printf("\nCaso queira encerrar, digite 0 -->\n");
    }
    while(1);
  printf("\n\nPrograma Encerrado!");
  return 0;
}
